# Host user IDs — run: id -u && id -g
PUID=1000
PGID=1000

# Timezone — e.g. Europe/London, America/New_York
TZ=Europe/London

# Absolute path to the data root
# Mac dev: ./data    Linux deploy: /mnt/data (or wherever your drives mount)
DATA_PATH=./data

# ExpressVPN credentials — from expressvpn.com dashboard (not your login email)
EXPRESSVPN_USERNAME=
EXPRESSVPN_PASSWORD=

# ExpressVPN server — country name or code, e.g. "UK", "USA", "Netherlands"
EXPRESSVPN_SERVER=UK
